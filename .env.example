# Overseer Environment Variables
# Copy to .env and fill in the values before running docker compose.

# ==================== Database ====================
POSTGRES_PASSWORD=change_me_in_production
# Used by API / Worker internally:
DATABASE_URL=postgresql+asyncpg://overseer:change_me_in_production@postgres:5432/overseer

# ==================== Security ====================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_min_32_chars
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FIELD_ENCRYPTION_KEY=generate_with_secrets_token_urlsafe_32

# ==================== Redis ====================
REDIS_URL=redis://redis:6379
# Production only – password-protected Redis:
# REDIS_PASSWORD=change_me_in_production
# REDIS_URL=redis://:change_me_in_production@redis:6379

# ==================== SMTP (for 2FA email codes) ====================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=monitoring@your-domain.com
SMTP_PASSWORD=change_me_in_production
SMTP_FROM=monitoring@your-domain.com

# ==================== CORS ====================
CORS_ORIGINS=https://yourdomain.com

# ==================== AI (optional) ====================
AI_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ==================== Lizenz (optional) ====================
LICENSE_KEY=

# ==================== Collector (set on each customer VM) ====================
# These are NOT used by docker compose – configure on each collector VM instead.
OVERSEER_API_URL=https://overseer.example.com
OVERSEER_RECEIVER_URL=https://overseer.example.com
OVERSEER_API_KEY=overseer_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# UUID assigned when the collector is created in the DB:
OVERSEER_COLLECTOR_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
