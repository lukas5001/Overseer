# Overseer Environment Variables
# Copy to .env and adjust for your environment

# ==================== Database ====================
POSTGRES_PASSWORD=change_me_in_production

# ==================== Security ====================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_in_production

# ==================== Redis ====================
REDIS_URL=redis://redis:6379

# ==================== Collector (on customer VM) ====================
OVERSEER_SERVER_URL=https://monitoring.example.com
OVERSEER_API_KEY=overseer_<tenant>_<secret>
OVERSEER_COLLECTOR_ID=collector-<customer-name>
